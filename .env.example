# ─────────────────────────────────────────────────────────────
# Silent Disco Platform — Environment Variables
# Copy to .env and fill in real values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Event Configuration ──────────────────────────────────────

# Unique identifier for this event (URL-safe string)
NEXT_PUBLIC_EVENT_ID=festival-2025

# Displayed in the web UI header
NEXT_PUBLIC_EVENT_NAME="Silent Disco at Summer Festival 2025"

# Optional venue name shown under the event title
NEXT_PUBLIC_EVENT_VENUE="Main Stage Arena, London"

# ── Streaming Infrastructure ─────────────────────────────────

# Base URL of your Icecast server (public-facing)
# Example: http://streaming.yourevent.com:8000
NEXT_PUBLIC_STREAMING_BASE_URL=http://localhost:8000

# Internal URL used by Next.js API routes → Icecast (server-to-server)
ICECAST_STATS_URL=http://localhost:8000

# ── Icecast Credentials ──────────────────────────────────────

ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_RELAY_PASSWORD=change-me-relay
ICECAST_ADMIN_PASSWORD=change-me-admin
ICECAST_HOSTNAME=localhost

# ── FFmpeg Encoder ────────────────────────────────────────────

# test | alsa | pulse | jack | rtmp
FFMPEG_INPUT_TYPE=test
AUDIO_BITRATE=128

# ALSA device overrides per channel (when INPUT_TYPE=alsa)
ALSA_CH1=hw:0,0
ALSA_CH2=hw:0,1
ALSA_CH3=hw:1,0
ALSA_CH4=hw:1,1

# ── API Service ───────────────────────────────────────────────

# Internal API URL (used by Next.js server components)
API_INTERNAL_URL=http://localhost:3001

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourevent.vercel.app

# Icecast stats URL (from API service perspective)
ICECAST_URL=http://localhost:8000

# ── Analytics (optional) ─────────────────────────────────────

# POST endpoint that receives AnalyticsEvent JSON objects
ANALYTICS_ENDPOINT=
ANALYTICS_API_KEY=

# ── Vercel (set in Vercel dashboard, not this file) ──────────

# VERCEL_URL is auto-set by Vercel
# Add these in Vercel project settings → Environment Variables:
#
#   NEXT_PUBLIC_EVENT_ID
#   NEXT_PUBLIC_EVENT_NAME
#   NEXT_PUBLIC_EVENT_VENUE
#   NEXT_PUBLIC_STREAMING_BASE_URL
#   ICECAST_STATS_URL
#   API_INTERNAL_URL

# Database
POSTGRES_USER=disco
POSTGRES_PASSWORD=discopass
DATABASE_URL=postgresql://disco:discopass@localhost:5432/silentdisco

# Auth
JWT_SECRET=change-this-to-a-secure-random-string-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Grafana
GRAFANA_PASSWORD=grafanapass
